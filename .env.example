# =============================================================
# Skylight Cloud — Environment Variables
# Copy this file to .env.local (local dev) or set in deployment
# =============================================================

# ---- Database ---------------------------------------------------
# PostgreSQL connection string (managed PostgreSQL recommended in prod)
DATABASE_URL=postgresql://user:password@localhost:5432/skylight_cloud

# ---- App --------------------------------------------------------
# Public URL of this deployment (no trailing slash)
APP_URL=http://localhost:3000

# Random 32+ byte secret — generate with: openssl rand -hex 32
AUTH_SECRET=change_me_to_a_random_secret

# Node environment
NODE_ENV=development

# ---- Email ------------------------------------------------------
# From address for outgoing email
EMAIL_FROM="Skylight Cloud <noreply@example.com>"

# Provider: "resend" | "smtp" (or leave blank for dev console logging)
EMAIL_PROVIDER=resend

# Resend API key (if using Resend)
EMAIL_PROVIDER_API_KEY=re_...

# SMTP settings (alternative to Resend)
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=user@example.com
# EMAIL_SMTP_PASS=password

# ---- Stripe -----------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in the Stripe dashboard
# Each is a recurring monthly price in USD
STRIPE_PRICE_1_TO_4=price_...     # $10/board/month (1-4 boards)
STRIPE_PRICE_5_TO_20=price_...    # $8/board/month  (5-20 boards)
STRIPE_PRICE_20_PLUS=price_...    # $7/board/month  (21+ boards)

# EMQX / MQTT fast path. Use EMQX Cloud TLS port 8883.
MQTT_HOST=your-emqx-deployment.emqxsl.com
MQTT_PORT=8883
MQTT_USERNAME=your-emqx-username
MQTT_PASSWORD=your-emqx-password
MQTT_TLS=true
MQTT_TOPIC_PREFIX=skylight
# Paste the EMQX deployment CA certificate. Use \n escapes if your host only accepts one-line env vars.
MQTT_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
